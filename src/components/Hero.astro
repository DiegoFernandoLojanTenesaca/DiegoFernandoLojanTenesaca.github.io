---

---

<section id="inicio" class="relative min-h-[85vh] flex items-center overflow-hidden pt-20 pb-12">
  <!-- Background orbs (subtle) -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="hero-gradient-orb absolute top-1/3 -left-40 w-72 h-72 bg-accent/6 rounded-full blur-3xl"></div>
    <div class="hero-gradient-orb absolute bottom-1/4 right-0 w-64 h-64 bg-accent-light/5 rounded-full blur-3xl" style="animation-delay: 3s;"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: Text content -->
      <div class="text-left">
        <div class="hero-animate hero-delay-1 flex items-end gap-3 mb-4">
          <img
            src={`${import.meta.env.BASE_URL}avatar-body.png`}
            alt=""
            class="w-12 h-12 sm:w-16 sm:h-16"
            style="image-rendering: pixelated;"
          />
          <p class="text-accent font-mono text-sm tracking-wider">
            &lt;developer /&gt;
          </p>
        </div>

        <h1 class="hero-animate hero-delay-2 text-4xl sm:text-5xl lg:text-6xl font-extrabold mb-3 tracking-tight leading-tight">
          Diego Fernando
          <span class="gradient-text block">Lojan Tenesaca</span>
        </h1>

        <h2 class="hero-animate hero-delay-3 text-lg sm:text-xl text-text-muted font-light mb-6">
          Full Stack Developer <span class="text-accent font-normal">|</span> Data & AI Engineer
        </h2>

        <p class="hero-animate hero-delay-4 max-w-lg text-text-muted text-base leading-relaxed mb-8" data-i18n="hero.tagline">
          De la arquitectura de software a los modelos de IA &mdash; diseño, construyo y despliego
          sistemas completos que resuelven problemas reales en producción.
        </p>

        <div class="hero-animate hero-delay-5 flex flex-col sm:flex-row items-start gap-4">
          <a
            href="#proyectos"
            class="group inline-flex items-center gap-2 px-6 py-3 bg-accent text-white font-medium rounded-lg hover:bg-accent-light transition-all duration-300 hover:shadow-lg hover:shadow-accent/25"
          >
            <span data-i18n="hero.cta.projects">Ver Proyectos</span>
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="#contacto"
            class="inline-flex items-center gap-2 px-6 py-3 border border-border text-text-muted font-medium rounded-lg hover:border-accent hover:text-accent transition-all duration-300"
            data-i18n="hero.cta.contact"
          >
            Contáctame
          </a>
          <a
            href={`${import.meta.env.BASE_URL}CV_DiegoLojan.pdf`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 text-text-muted font-medium hover:text-accent transition-colors duration-300"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            CV
          </a>
        </div>
      </div>

      <!-- Right: Terminal widget with rotating snippets -->
      <div class="hero-animate hero-delay-3 hidden lg:block">
        <div class="terminal-window bg-surface border border-border rounded-xl overflow-hidden shadow-2xl shadow-black/30">
          <!-- Terminal top bar -->
          <div class="flex items-center gap-2 px-4 py-3 bg-surface-light border-b border-border">
            <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
            <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
            <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
            <span id="terminal-filename" class="ml-3 text-xs text-text-muted font-mono">pipeline.py</span>
          </div>

          <!-- Snippet containers -->
          <div class="relative" style="min-height: 290px;">
            <!-- Snippet 1: pipeline.py -->
            <div class="snippet-panel snippet-active p-5 font-mono text-[13px] leading-relaxed" data-file="pipeline.py">
              <div class="terminal-line tl-1"><span class="text-accent">from</span> langchain.chains <span class="text-accent">import</span> RetrievalQA</div>
              <div class="terminal-line tl-2"><span class="text-accent">from</span> fastapi <span class="text-accent">import</span> FastAPI</div>
              <div class="terminal-line tl-3">&nbsp;</div>
              <div class="terminal-line tl-4">app = <span class="text-accent-light">FastAPI</span>(title=<span class="text-[#a3e635]">"Sudial AI"</span>)</div>
              <div class="terminal-line tl-5">&nbsp;</div>
              <div class="terminal-line tl-6"><span class="text-accent">@</span><span class="text-accent-light">app.post</span>(<span class="text-[#a3e635]">"/query"</span>)</div>
              <div class="terminal-line tl-7"><span class="text-accent">async def</span> <span class="text-accent-light">semantic_search</span>(q: <span class="text-accent-light">str</span>):</div>
              <div class="terminal-line tl-8">    chain = <span class="text-accent-light">RetrievalQA</span>.from_chain_type(</div>
              <div class="terminal-line tl-9">        llm=<span class="text-text-muted">llm</span>,</div>
              <div class="terminal-line tl-10">        retriever=<span class="text-text-muted">vectorstore</span>.as_retriever()</div>
              <div class="terminal-line tl-11">    )</div>
              <div class="terminal-line tl-12">    <span class="text-accent">return</span> chain.invoke(q)</div>
              <div class="terminal-line tl-13"><span class="terminal-cursor"></span></div>
            </div>

            <!-- Snippet 2: websocket.py -->
            <div class="snippet-panel p-5 font-mono text-[13px] leading-relaxed" data-file="websocket.py">
              <div class="terminal-line tl-1"><span class="text-accent">from</span> autobahn.twisted <span class="text-accent">import</span> WebSocketServerProtocol</div>
              <div class="terminal-line tl-2">&nbsp;</div>
              <div class="terminal-line tl-3"><span class="text-accent">class</span> <span class="text-accent-light">ChatProtocol</span>(WebSocketServerProtocol):</div>
              <div class="terminal-line tl-4">&nbsp;</div>
              <div class="terminal-line tl-5">    <span class="text-accent">def</span> <span class="text-accent-light">onMessage</span>(self, payload, isBinary):</div>
              <div class="terminal-line tl-6">        data = json.loads(payload)</div>
              <div class="terminal-line tl-7">        org_id = data[<span class="text-[#a3e635]">"org_id"</span>]</div>
              <div class="terminal-line tl-8">        message = data[<span class="text-[#a3e635]">"message"</span>]</div>
              <div class="terminal-line tl-9">&nbsp;</div>
              <div class="terminal-line tl-10">        <span class="text-accent">await</span> self.broadcast(</div>
              <div class="terminal-line tl-11">            org_id, message</div>
              <div class="terminal-line tl-12">        )</div>
              <div class="terminal-line tl-13"><span class="terminal-cursor"></span></div>
            </div>

            <!-- Snippet 3: component.tsx -->
            <div class="snippet-panel p-5 font-mono text-[13px] leading-relaxed" data-file="ChatView.tsx">
              <div class="terminal-line tl-1"><span class="text-accent">import</span> &#123; useState &#125; <span class="text-accent">from</span> <span class="text-[#a3e635]">"react"</span></div>
              <div class="terminal-line tl-2"><span class="text-accent">import</span> &#123; useAuth &#125; <span class="text-accent">from</span> <span class="text-[#a3e635]">"@/contexts/AuthContext"</span></div>
              <div class="terminal-line tl-3">&nbsp;</div>
              <div class="terminal-line tl-4"><span class="text-accent">export default function</span> <span class="text-accent-light">ChatView</span>() &#123;</div>
              <div class="terminal-line tl-5">    <span class="text-accent">const</span> &#123; orgId, user &#125; = <span class="text-accent-light">useAuth</span>()</div>
              <div class="terminal-line tl-6">    <span class="text-accent">const</span> [msgs, setMsgs] = <span class="text-accent-light">useState</span>([])</div>
              <div class="terminal-line tl-7">&nbsp;</div>
              <div class="terminal-line tl-8">    <span class="text-accent">const</span> <span class="text-accent-light">sendMessage</span> = <span class="text-accent">async</span> (text) =&gt; &#123;</div>
              <div class="terminal-line tl-9">        <span class="text-accent">await</span> apiService.<span class="text-accent-light">post</span>(<span class="text-[#a3e635]">"/messages"</span>, &#123;</div>
              <div class="terminal-line tl-10">            org_id: orgId, body: text</div>
              <div class="terminal-line tl-11">        &#125;)</div>
              <div class="terminal-line tl-12">    &#125;</div>
              <div class="terminal-line tl-13"><span class="terminal-cursor"></span></div>
            </div>

            <!-- Snippet 4: etl_pipeline.py -->
            <div class="snippet-panel p-5 font-mono text-[13px] leading-relaxed" data-file="embeddings.py">
              <div class="terminal-line tl-1"><span class="text-accent">from</span> langchain.text_splitter <span class="text-accent">import</span> RecursiveCharacterTextSplitter</div>
              <div class="terminal-line tl-2"><span class="text-accent">from</span> pgvector.sqlalchemy <span class="text-accent">import</span> Vector</div>
              <div class="terminal-line tl-3">&nbsp;</div>
              <div class="terminal-line tl-4"><span class="text-accent">def</span> <span class="text-accent-light">ingest_documents</span>(docs):</div>
              <div class="terminal-line tl-5">    splitter = <span class="text-accent-light">RecursiveCharacterTextSplitter</span>(</div>
              <div class="terminal-line tl-6">        chunk_size=<span class="text-text-muted">500</span>,</div>
              <div class="terminal-line tl-7">        chunk_overlap=<span class="text-text-muted">50</span></div>
              <div class="terminal-line tl-8">    )</div>
              <div class="terminal-line tl-9">    chunks = splitter.<span class="text-accent-light">split_documents</span>(docs)</div>
              <div class="terminal-line tl-10">    embeddings = <span class="text-accent-light">get_embeddings</span>(chunks)</div>
              <div class="terminal-line tl-11">&nbsp;</div>
              <div class="terminal-line tl-12">    db.session.<span class="text-accent-light">bulk_save_objects</span>(embeddings)</div>
              <div class="terminal-line tl-13"><span class="terminal-cursor"></span></div>
            </div>
          </div>
        </div>
      </div>

      <script is:inline>
        (function() {
          if (window.__terminalInterval) clearInterval(window.__terminalInterval);
          var panels = document.querySelectorAll(".snippet-panel");
          var filenameEl = document.getElementById("terminal-filename");
          if (!panels.length || !filenameEl) return;
          var current = 0;
          window.__terminalInterval = setInterval(function() {
            panels[current].classList.remove("snippet-active");
            current = (current + 1) % panels.length;
            panels[current].classList.add("snippet-active");
            filenameEl.textContent = panels[current].getAttribute("data-file") || "";
          }, 6000);
        })();
      </script>

    </div>
  </div>
</section>

<style>
  /* Snippet panels: only active one is visible */
  .snippet-panel {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  .snippet-panel.snippet-active {
    position: relative;
    opacity: 1;
    pointer-events: auto;
  }

  /* Re-trigger line animations when panel becomes active */
  .snippet-active .terminal-line {
    opacity: 0;
    animation: terminal-type 0.25s ease forwards;
    white-space: nowrap;
  }

  .snippet-active .tl-1  { animation-delay: 0.15s; }
  .snippet-active .tl-2  { animation-delay: 0.30s; }
  .snippet-active .tl-3  { animation-delay: 0.42s; }
  .snippet-active .tl-4  { animation-delay: 0.54s; }
  .snippet-active .tl-5  { animation-delay: 0.66s; }
  .snippet-active .tl-6  { animation-delay: 0.78s; }
  .snippet-active .tl-7  { animation-delay: 0.90s; }
  .snippet-active .tl-8  { animation-delay: 1.02s; }
  .snippet-active .tl-9  { animation-delay: 1.14s; }
  .snippet-active .tl-10 { animation-delay: 1.26s; }
  .snippet-active .tl-11 { animation-delay: 1.38s; }
  .snippet-active .tl-12 { animation-delay: 1.50s; }
  .snippet-active .tl-13 { animation-delay: 1.62s; }

  /* Hide lines in non-active panels */
  .snippet-panel:not(.snippet-active) .terminal-line {
    opacity: 0;
    animation: none;
  }

  @keyframes terminal-type {
    0% {
      opacity: 0;
      transform: translateX(-4px);
    }
    100% {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Blinking cursor */
  .terminal-cursor {
    display: inline-block;
    width: 8px;
    height: 18px;
    background-color: var(--color-accent);
    animation: cursor-blink 1s step-end infinite;
    vertical-align: text-bottom;
  }

  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* Terminal window subtle glow */
  .terminal-window {
    position: relative;
  }
  .terminal-window::after {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, var(--color-accent-glow), transparent 50%);
    z-index: -1;
    opacity: 0.5;
  }
</style>
