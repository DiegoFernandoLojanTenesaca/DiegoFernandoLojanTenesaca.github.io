---
import { projects } from "../data/projects";

const projKeys: Record<string, string> = {
  "Sudial": "proj.sudial.desc",
  "Sudial AI": "proj.sudialai.desc",
  "Machine Learning Hub": "proj.mlhub.desc",
  "Análisis Electoral Ecuador 2025": "proj.electoral.desc",
  "Detección de Estrés en Redes Sociales": "proj.stress.desc",
  "Vosk - Reconocimiento de Voz": "proj.vosk.desc",
};
---

<section id="proyectos" class="py-16 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
  <!-- Avatar con espada -->
  <img
    src={`${import.meta.env.BASE_URL}avatar-sword.png`}
    alt=""
    class="absolute bottom-4 right-2 sm:bottom-12 sm:right-6 w-14 h-14 sm:w-20 sm:h-20 xl:w-28 xl:h-28 opacity-35 sm:opacity-50 hover:opacity-90 transition-opacity pointer-events-none"
    style="image-rendering: pixelated;"
  />
  <div class="max-w-6xl mx-auto">
    <div class="reveal text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">
        <span class="gradient-text" data-i18n="proj.title">Proyectos</span>
      </h2>
      <p class="text-text-muted max-w-xl mx-auto" data-i18n="proj.subtitle">
        Proyectos profesionales y personales en los que he trabajado
      </p>
    </div>

    <div class="reveal-stagger grid md:grid-cols-2 gap-6">
      {projects.map((project) => (
        <div
          class:list={[
            "group bg-surface border border-border rounded-xl overflow-hidden hover:border-accent/30 transition-all duration-300",
            project.featured && "md:col-span-1",
          ]}
        >
          <div class="p-6">
          <!-- Header -->
          <div class="flex items-start justify-between mb-3">
            <h3 class="text-lg font-semibold text-text group-hover:text-accent transition-colors">
              {project.title}
            </h3>

            <!-- Links -->
            <div class="flex items-center gap-1.5">
              {project.github && (
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-text-muted hover:text-accent transition-colors p-1"
                  aria-label={`GitHub: ${project.title}`}
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                  </svg>
                </a>
              )}
              {project.kaggle && (
                <a
                  href={project.kaggle}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-text-muted hover:text-[#20beff] transition-colors p-1"
                  aria-label={`Kaggle: ${project.title}`}
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M18.825 23.859c-.022.092-.117.141-.281.141h-3.139c-.187 0-.351-.082-.492-.248l-5.178-6.589-1.448 1.374v5.111c0 .235-.117.352-.351.352H5.505c-.236 0-.354-.117-.354-.352V.353c0-.233.118-.353.354-.353h2.431c.234 0 .351.12.351.353v14.343l6.203-6.272c.165-.165.33-.246.495-.246h3.239c.144 0 .236.06.281.18.046.149.034.255-.036.315l-6.555 6.344 6.836 8.507c.095.104.117.208.075.312"/>
                  </svg>
                </a>
              )}
              {project.demo && (
                <a
                  href={project.demo}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-text-muted hover:text-accent transition-colors p-1"
                  aria-label={`Demo: ${project.title}`}
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              )}
              {!project.github && !project.demo && (
                <span class="px-2 py-0.5 text-[10px] font-mono text-text-muted/60 border border-border rounded" data-i18n="proj.private">
                  Privado
                </span>
              )}
            </div>
          </div>

          <!-- Description -->
          <p class="text-sm text-text-muted leading-relaxed mb-4" data-i18n={projKeys[project.title]}>
            {project.description}
          </p>

          <!-- Tags -->
          <div class="flex flex-wrap gap-1.5">
            {project.tags.map((tag) => (
              <span class="px-2 py-0.5 text-[11px] font-mono bg-accent-soft text-accent-light rounded">
                {tag}
              </span>
            ))}
          </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
