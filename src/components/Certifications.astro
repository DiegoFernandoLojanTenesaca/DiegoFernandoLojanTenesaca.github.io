---
const certifications = [
  {
    title: "Introduction to Data Science",
    issuer: "Cisco Networking Academy",
    icon: "data",
  },
  {
    title: "Curso Introductorio Data Science",
    issuer: "Nuclio Digital School",
    icon: "data",
  },
  {
    title: "Gestión de Amenazas Cibernéticas",
    issuer: "Cisco Networking Academy",
    icon: "security",
  },
  {
    title: "React y Spring Boot: App Full Stack",
    issuer: "Udemy",
    icon: "dev",
  },
  {
    title: "Scrum Master y Product Owner",
    issuer: "Udemy",
    icon: "agile",
  },
  {
    title: "Diplomado en Aprendizaje Basado en Proyectos",
    issuer: "Politécnico de Colombia · 120h",
    icon: "edu",
  },
];

const iconMap: Record<string, string> = {
  data: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
  security: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
  dev: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4",
  agile: "M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15",
  edu: "M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222",
};
---

<section id="certificaciones" class="py-16 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <div class="reveal text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">
        <span class="gradient-text" data-i18n="cert.title">Certificaciones</span>
      </h2>
      <p class="text-text-muted max-w-xl mx-auto" data-i18n="cert.subtitle">
        Formación continua en tecnología, datos e inteligencia artificial.
      </p>
    </div>

    <div class="reveal grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {certifications.map((cert) => (
        <div class="bg-surface border border-border rounded-xl p-5 hover:border-accent/30 transition-colors duration-300 group">
          <div class="flex items-start gap-3">
            <div class="w-9 h-9 rounded-lg bg-accent-soft flex items-center justify-center shrink-0 group-hover:bg-accent/20 transition-colors">
              <svg class="w-4.5 h-4.5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={iconMap[cert.icon]} />
              </svg>
            </div>
            <div>
              <p class="text-sm text-text font-medium leading-snug">{cert.title}</p>
              <p class="text-xs text-text-muted mt-1">{cert.issuer}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
