---

<section id="tecnologias" class="py-16 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
  <!-- Avatar de lado -->
  <img
    src={`${import.meta.env.BASE_URL}avatar-side.png`}
    alt=""
    class="absolute bottom-4 left-2 sm:left-6 w-12 h-12 sm:w-16 sm:h-16 xl:w-20 xl:h-20 opacity-40 sm:opacity-50 hover:opacity-90 transition-opacity pointer-events-none"
    style="image-rendering: pixelated;"
  />
  <div class="max-w-6xl mx-auto">
    <div class="reveal mb-10">
      <h2 class="text-3xl sm:text-4xl font-bold mb-3">
        <span class="gradient-text" data-i18n="tech.title">Tecnologías</span>
      </h2>
      <p class="text-text-muted text-lg" data-i18n="tech.subtitle">
        Mi stack tecnológico en constante evolución
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6">
      {skillCategories.map((category) => (
        <div class="reveal">
          <h3 class="text-xs font-mono text-accent mb-3 uppercase tracking-wider" data-i18n={catKeys[category.name]}>
            {category.name}
          </h3>
          <div class="flex flex-wrap gap-1.5">
            {category.skills.map((skill) => {
              const iconUrl = techIcons[skill.icon];
              return (
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-surface border border-border rounded text-xs text-text-muted hover:text-text hover:border-accent/50 transition-colors cursor-default">
                  {iconUrl ? (
                    <img
                      src={iconUrl}
                      alt=""
                      class="w-3.5 h-3.5"
                      loading="lazy"
                    />
                  ) : (
                    <span class="w-3.5 h-3.5 rounded-sm bg-accent/20 flex items-center justify-center text-[8px] font-bold text-accent leading-none">
                      {skill.name.charAt(0)}
                    </span>
                  )}
                  {skill.name}
                </span>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
