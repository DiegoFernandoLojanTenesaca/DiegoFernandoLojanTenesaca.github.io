---

<section id="contacto" class="py-16 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
  <!-- Avatar saludando -->
  <img
    src={`${import.meta.env.BASE_URL}avatar-wave.png`}
    alt=""
    class="absolute top-4 left-2 sm:top-12 sm:left-8 w-12 h-12 sm:w-16 sm:h-16 xl:w-20 xl:h-20 opacity-55 sm:opacity-65 hover:opacity-100 transition-opacity pointer-events-none"
    style="image-rendering: pixelated;"
  />
  <div class="max-w-3xl mx-auto text-center">
    <div class="reveal">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">
        <span class="gradient-text" data-i18n="contact.title">Contacto</span>
      </h2>
      <p class="text-text-muted mb-4 max-w-lg mx-auto" data-i18n="contact.subtitle">
        ¿Tienes un proyecto en mente o quieres colaborar? Hablemos.
      </p>
      <p class="text-text-muted/60 text-sm mb-10 font-mono" data-i18n="contact.location">
        Loja, Ecuador &middot; Disponible para trabajo remoto
      </p>
    </div>

    <!-- Social links -->
    <div class="reveal-stagger flex flex-wrap items-center justify-center gap-4">
      {socials.map((social) => (
        <a
          href={social.url}
          target={social.url.startsWith("mailto") ? undefined : "_blank"}
          rel={social.url.startsWith("mailto") ? undefined : "noopener noreferrer"}
          class="glow-hover group flex items-center gap-2.5 px-5 py-3 bg-surface border border-border rounded-xl hover:border-accent/40 transition-all duration-300"
          aria-label={social.name}
        >
          <svg
            class="w-5 h-5 text-text-muted group-hover:text-accent transition-colors"
            fill={social.name === "Email" ? "none" : "currentColor"}
            stroke={social.name === "Email" ? "currentColor" : "none"}
            viewBox="0 0 24 24"
          >
            <Fragment set:html={social.icon} />
          </svg>
          <span class="text-sm text-text-muted group-hover:text-text transition-colors font-medium">
            {social.name}
          </span>
        </a>
      ))}
    </div>

    <!-- Conexiones -->
    <div class="reveal mt-14 pt-10 border-t border-border/50">
      <p class="text-xs font-mono text-text-muted/60 uppercase tracking-wider mb-5" data-i18n="contact.connections">Conexiones</p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a
          href="https://github.com/jahirxtrap"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 px-4 py-2.5 bg-surface border border-border rounded-lg hover:border-accent/40 transition-all duration-300 group"
        >
          <img
            src="https://github.com/jahirxtrap.png"
            alt="jahirtrap"
            class="w-8 h-8 rounded-full border border-border group-hover:border-accent/50"
            loading="lazy"
          />
          <div class="text-left">
            <p class="text-sm text-text font-medium group-hover:text-accent transition-colors">jahirtrap</p>
            <p class="text-[11px] text-text-muted" data-i18n="conn.jahir">Developer</p>
          </div>
        </a>
        <a
          href="https://github.com/Graclyxz"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 px-4 py-2.5 bg-surface border border-border rounded-lg hover:border-accent/40 transition-all duration-300 group"
        >
          <img
            src="https://github.com/Graclyxz.png"
            alt="Xavier Villavicencio"
            class="w-8 h-8 rounded-full border border-border group-hover:border-accent/50"
            loading="lazy"
          />
          <div class="text-left">
            <p class="text-sm text-text font-medium group-hover:text-accent transition-colors">Ing. Xavier Villavicencio</p>
            <p class="text-[11px] text-text-muted" data-i18n="conn.xavier">Ing. Software</p>
          </div>
        </a>
        <a
          href="https://github.com/MariaDSalazar"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 px-4 py-2.5 bg-surface border border-border rounded-lg hover:border-accent/40 transition-all duration-300 group"
        >
          <img
            src="https://github.com/MariaDSalazar.png"
            alt="María del Carmen Salazar"
            class="w-8 h-8 rounded-full border border-border group-hover:border-accent/50"
            loading="lazy"
          />
          <div class="text-left">
            <p class="text-sm text-text font-medium group-hover:text-accent transition-colors">Ing. María Salazar</p>
            <p class="text-[11px] text-text-muted" data-i18n="conn.maria">Ing. Computacion & Docente</p>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>
